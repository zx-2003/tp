@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":TutorMapParser" as TutorMapParser LOGIC_COLOR
participant "u:UndoCommand" as UndoCommand LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant ":Model" as Model MODEL_COLOR
end box
[-> LogicManager : execute(undo)
activate LogicManager

LogicManager -> TutorMapParser : parseCommand(undo)
activate TutorMapParser

create UndoCommand
TutorMapParser -> UndoCommand
activate UndoCommand

UndoCommand --> TutorMapParser
deactivate UndoCommand

TutorMapParser --> LogicManager : u
deactivate TutorMapParser

LogicManager -> UndoCommand : execute()
activate UndoCommand

UndoCommand -> Model : undoTutorMap()
activate Model

Model --> UndoCommand
deactivate Model

UndoCommand --> LogicManager : result
deactivate UndoCommand
UndoCommand -[hidden]-> LogicManager : result
destroy UndoCommand

[<--LogicManager
deactivate LogicManager
@enduml
