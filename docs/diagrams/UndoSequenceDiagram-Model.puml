@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Model MODEL_COLOR_T1
participant ":Model" as Model MODEL_COLOR
participant ":VersionedTutorMap" as VersionedTutorMap MODEL_COLOR
end box

[-> Model : undoTutorMap()
activate Model

Model -> VersionedTutorMap : undo()
activate VersionedTutorMap

VersionedTutorMap -> VersionedTutorMap :resetData(ReadOnlyTutorMap)
VersionedTutorMap --> Model :
deactivate VersionedTutorMap

[<-- Model
deactivate Model

@enduml
